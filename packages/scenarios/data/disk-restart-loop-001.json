{
  "id": "disk-restart-loop-001",
  "version": 1,
  "title": "再起動ループの夜",
  "difficulty": "advanced",
  "timeLimitMinutes": 15,
  "service": { "name": "うん用 API", "healthUrl": "http://localhost:8080/health" },
  "briefing": ["disk full のまま再起動するとすぐ再障害する。", "容量を確保してから再起動する。"],
  "startup": [
    { "id": "api", "command": "PORT=8080 node /workspace/services/unyoh-api/server.mjs", "waitForPort": 8080 },
    { "id": "fake-db", "command": "node /workspace/services/fake-db/server.mjs", "waitForPort": 15432 }
  ],
  "triggers": [{ "id": "loop", "atMs": 60000, "type": "composite_restart_loop", "params": { "diskPath": "/workspace/logs/debug.log", "bytes": 838860800, "processId": "api" } }],
  "alerts": [
    { "id": "disk-full", "atMs": 70000, "severity": "critical", "message": "Disk usage is above 95%", "source": "monitor" },
    { "id": "api-down", "atMs": 80000, "severity": "critical", "message": "API process is down", "source": "scenario" }
  ],
  "successConditions": [
    { "type": "http_status", "url": "http://localhost:8080/health", "status": 200 },
    { "type": "disk_usage_below", "path": "/workspace", "valuePercent": 80 },
    { "type": "process_running", "processId": "api" }
  ],
  "runbooks": [{ "id": "runbook.loop", "title": "再起動ループ", "body": "1. df -h\\n2. ログ削除\\n3. unctl restart api\\n4. health 確認" }],
  "slackMessages": []
}
