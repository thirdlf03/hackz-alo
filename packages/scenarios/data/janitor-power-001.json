{
  "id": "janitor-power-001",
  "version": 1,
  "title": "掃除のおばちゃんが電源を抜いた夜",
  "difficulty": "intermediate",
  "timeLimitMinutes": 5,
  "service": {
    "name": "やまびこ API",
    "healthUrl": "http://localhost:8080/health"
  },
  "briefing": [
    "深夜のデータセンターには掃除のおばちゃんが巡回している。",
    "冗長系の片方を掃除中に抜かれると API が落ちる。",
    "app.log と run/ 配下のマーカーを確認してから復旧する。"
  ],
  "startup": [
    {
      "id": "api",
      "command": "PORT=8080 node /workspace/services/yamabiko-api/server.mjs",
      "waitForPort": 8080
    },
    {
      "id": "fake-db",
      "command": "node /workspace/services/fake-db/server.mjs",
      "waitForPort": 15432
    }
  ],
  "topology": {
    "nodes": [
      {
        "id": "user",
        "label": "ユーザー",
        "kind": "external"
      },
      {
        "id": "api",
        "label": "やまびこ API",
        "kind": "service",
        "processId": "api"
      },
      {
        "id": "fake-db",
        "label": "疑似データベース",
        "kind": "datastore",
        "processId": "fake-db"
      },
      {
        "id": "power",
        "label": "電源",
        "kind": "external"
      }
    ],
    "edges": [
      {
        "from": "user",
        "to": "api"
      },
      {
        "from": "api",
        "to": "fake-db"
      },
      {
        "from": "api",
        "to": "power"
      }
    ]
  },
  "triggers": [
    {
      "id": "janitor-pull",
      "atMs": 60000,
      "type": "janitor_power_pull",
      "params": {
        "processId": "api"
      }
    }
  ],
  "alerts": [
    {
      "id": "power-lost",
      "atMs": 75000,
      "severity": "critical",
      "message": "やまびこ API health check failed",
      "source": "monitor"
    },
    {
      "id": "janitor-cam",
      "atMs": 90000,
      "severity": "warning",
      "message": "Janitor camera detected unplugged cable",
      "source": "scenario"
    }
  ],
  "successConditions": [
    {
      "type": "http_status",
      "url": "http://localhost:8080/health",
      "status": 200
    },
    {
      "type": "process_running",
      "processId": "api"
    },
    {
      "type": "marker_absent",
      "path": "/workspace/run/janitor.power.pulled"
    }
  ],
  "runbooks": [
    {
      "id": "runbook.janitor",
      "title": "掃除による電源断",
      "body": "1. curl localhost:8080/health で影響確認\\n2. yamactl status api でプロセス状態を見る\\n3. ls /workspace/run で物理的な原因の痕跡(janitor.power.pulled)を探す\\n4. 痕跡を記録して片付け(rm)、yamactl restart api\\n5. health で復旧確認"
    }
  ],
  "chatMessages": [
    {
      "id": "janitor-sorry",
      "atMs": 100000,
      "from": "掃除のおばちゃん",
      "body": "ごめんなさい、掃除中に抜いちゃいました。"
    }
  ],
  "navigationSteps": [
    {
      "id": "nav-health",
      "atMs": 0,
      "hint": "SERVICE HEALTH が緑か確認する",
      "panel": "metrics"
    },
    {
      "id": "nav-marker",
      "atMs": 45000,
      "hint": "ls /workspace/run で怪しいマーカーを探す",
      "panel": "terminal",
      "suggestedCommand": "ls -la /workspace/run"
    },
    {
      "id": "nav-runbook",
      "atMs": 70000,
      "hint": "掃除による電源断 Runbook を開く",
      "panel": "runbook"
    }
  ]
}
