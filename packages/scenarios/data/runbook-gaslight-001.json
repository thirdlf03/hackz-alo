{
  "id": "runbook-gaslight-001",
  "version": 1,
  "title": "Runbook が「気合いで直す」に化けた夜",
  "difficulty": "intermediate",
  "timeLimitMinutes": 10,
  "service": {
    "name": "やまびこ API",
    "healthUrl": "http://localhost:8080/health"
  },
  "briefing": [
    "社内 Wiki(Runbook)が改ざんされている可能性がある。画面に表示される手順が正しいとは限らない。",
    "サービス自体は動いている。慌てず、まず手順書の内容そのものを疑うところから始める。",
    "「書いてある通りにやる」を疑えるかどうかが、今夜の分かれ目。"
  ],
  "startup": [
    {
      "id": "api",
      "command": "PORT=8080 node /workspace/services/yamabiko-api/server.mjs",
      "waitForPort": 8080
    },
    {
      "id": "fake-db",
      "command": "node /workspace/services/fake-db/server.mjs",
      "waitForPort": 15432
    }
  ],
  "topology": {
    "nodes": [
      {
        "id": "user",
        "label": "ユーザー",
        "kind": "external"
      },
      {
        "id": "api",
        "label": "やまびこ API",
        "kind": "service",
        "processId": "api"
      },
      {
        "id": "fake-db",
        "label": "疑似データベース",
        "kind": "datastore",
        "processId": "fake-db"
      }
    ],
    "edges": [
      {
        "from": "user",
        "to": "api"
      },
      {
        "from": "api",
        "to": "fake-db"
      }
    ]
  },
  "triggers": [
    {
      "id": "gaslight",
      "atMs": 40000,
      "type": "runbook_gaslight",
      "params": {
        "replacement": "気合いで直す。根性。深呼吸。"
      }
    }
  ],
  "alerts": [
    {
      "id": "runbook-tamper",
      "atMs": 55000,
      "severity": "warning",
      "message": "Runbook integrity check failed",
      "source": "scenario"
    }
  ],
  "successConditions": [
    {
      "type": "http_status",
      "url": "http://localhost:8080/health",
      "status": 200
    },
    {
      "type": "log_absent",
      "path": "/workspace/docs/runbooks/service-recovery.md",
      "pattern": "気合いで直す"
    }
  ],
  "runbooks": [
    {
      "id": "runbook.gaslight",
      "title": "サービス復旧手順(社内 Wiki)",
      "file": "/workspace/docs/runbooks/service-recovery.md",
      "body": "1. curl -s localhost:8080/health で実際の状態を確認する\n2. yamactl status api / yamactl status fake-db でプロセスとポートの状態を見る\n3. プロセスが死んでいれば yamactl restart <service> で再起動する\n4. 設定が壊れていれば /workspace/releases/*.previous.json から復元する\n5. ディスクが逼迫していれば不要なログを削除してから yamactl restart api\n6. 監視エージェントが応答しなければ yamactl restart monitor-agent"
    }
  ],
  "chatMessages": [
    {
      "id": "wiki-broken",
      "atMs": 65000,
      "from": "先輩",
      "body": "Wiki 壊れてる。Runbook 信じないで。"
    }
  ],
  "navigationSteps": [
    {
      "id": "nav-runbook",
      "atMs": 0,
      "hint": "Runbook パネルの内容を一度読んでおく",
      "panel": "runbook"
    },
    {
      "id": "nav-doubt",
      "atMs": 45000,
      "hint": "Runbook の文言に違和感がないか、書いてある通りに動いて大丈夫か疑ってみる",
      "panel": "runbook"
    },
    {
      "id": "nav-find-backup",
      "atMs": 60000,
      "hint": "手順書が改ざんされているなら、正しい版がどこかに残っていないか探す",
      "panel": "terminal",
      "suggestedCommand": "ls /workspace/docs/backups"
    },
    {
      "id": "nav-restore",
      "atMs": 75000,
      "hint": "バックアップから Runbook を復元する",
      "panel": "terminal",
      "suggestedCommand": "cp /workspace/docs/backups/service-recovery.md /workspace/docs/runbooks/service-recovery.md"
    },
    {
      "id": "nav-health",
      "atMs": 90000,
      "hint": "curl で実際のヘルスを確認する",
      "panel": "terminal",
      "suggestedCommand": "curl localhost:8080/health"
    }
  ]
}
