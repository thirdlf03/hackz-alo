{
  "id": "cable-jumprope-001",
  "version": 1,
  "title": "LANケーブル縄跳びの夜",
  "difficulty": "intermediate",
  "timeLimitMinutes": 5,
  "service": {
    "name": "やまびこ API",
    "healthUrl": "http://localhost:8080/health"
  },
  "briefing": [
    "ネットワーク断に見えても、実は誰かが LAN ケーブルで縄跳びしているだけかもしれない。",
    "network.jumprope マーカーと hosts.override を確認する。",
    "ケーブルを戻してから API を再起動する。"
  ],
  "startup": [
    {
      "id": "api",
      "command": "PORT=8080 node /workspace/services/yamabiko-api/server.mjs",
      "waitForPort": 8080
    },
    {
      "id": "fake-db",
      "command": "node /workspace/services/fake-db/server.mjs",
      "waitForPort": 15432
    }
  ],
  "triggers": [
    {
      "id": "jumprope",
      "atMs": 55000,
      "type": "cable_jumprope",
      "params": {
        "hostsPath": "/workspace/run/hosts.override"
      }
    }
  ],
  "alerts": [
    {
      "id": "net-down",
      "atMs": 70000,
      "severity": "critical",
      "message": "Network unreachable to API host",
      "source": "monitor"
    },
    {
      "id": "eth0-flap",
      "atMs": 85000,
      "severity": "warning",
      "message": "eth0 link flapping detected",
      "source": "scenario"
    }
  ],
  "successConditions": [
    {
      "type": "http_status",
      "url": "http://localhost:8080/health",
      "status": 200
    },
    {
      "type": "process_running",
      "processId": "api"
    },
    {
      "type": "marker_absent",
      "path": "/workspace/run/network.jumprope"
    }
  ],
  "runbooks": [
    {
      "id": "runbook.jumprope",
      "title": "ケーブル縄跳び対応",
      "body": "1. cat /workspace/run/network.jumprope で状況確認\\n2. rm /workspace/run/network.jumprope /workspace/run/hosts.override /workspace/run/api.down\\n3. yamactl restart api\\n4. curl localhost:8080/health"
    }
  ],
  "chatMessages": [
    {
      "id": "infra-joke",
      "atMs": 95000,
      "from": "インフラ",
      "body": "縄跳び大会やってる？ ping 通らないんだけど。"
    }
  ],
  "navigationSteps": [
    {
      "id": "nav-ping",
      "atMs": 30000,
      "hint": "curl localhost:8080/health で疎通を確認する",
      "panel": "terminal",
      "suggestedCommand": "curl localhost:8080/health"
    },
    {
      "id": "nav-run",
      "atMs": 60000,
      "hint": "/workspace/run のマーカーを調べる",
      "panel": "terminal",
      "suggestedCommand": "ls -la /workspace/run"
    },
    {
      "id": "nav-runbook",
      "atMs": 80000,
      "hint": "ケーブル縄跳び Runbook を参照する",
      "panel": "runbook"
    }
  ]
}
