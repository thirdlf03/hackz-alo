{
  "name": "incident-training-sim",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "test": "node --test tests/unit/*.mjs",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage tests/unit/*.mjs",
    "test:coverage:check": "node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-lines=73.02 tests/unit/*.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test game-success game-failure terminal editor replay-access",
    "test:vrt": "playwright test -c playwright.vrt.config.ts",
    "test:integration": "node --test tests/integration/*.mjs",
    "build:scenarios": "tsx scripts/build-scenarios.mjs",
    "db:migrate:local": "pnpm --filter @incident/worker run db:migrate:local",
    "db:reset:local": "node scripts/db-reset-local.mjs",
    "sync:sandbox-assets": "node scripts/sync-sandbox-assets.mjs",
    "check:sandbox-assets": "node scripts/check-sandbox-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm -r run build",
    "setup:cloudflare": "node scripts/setup-cloudflare.mjs",
    "setup:edge": "node scripts/setup-edge-security.mjs",
    "setup:domain": "node scripts/setup-custom-domain.mjs",
    "setup:ops": "node scripts/setup-production-ops.mjs",
    "load-test": "node scripts/load-test.mjs",
    "perf:bench": "node scripts/perf-bench.mjs",
    "perf:e2e": "node scripts/perf-e2e.mjs",
    "perf:report": "node scripts/perf-report.mjs",
    "perf:compare": "node scripts/perf-compare.mjs --strict",
    "perf:baseline:accept": "node scripts/perf-baseline-accept.mjs",
    "perf:placement:verify": "node scripts/perf-placement-verify.mjs",
    "bench:ai-assist": "node scripts/ai-assist-bench.mjs",
    "deploy": "node scripts/deploy.mjs",
    "deploy:smoke": "node scripts/deploy-smoke.mjs",
    "cleanup:sessions": "node scripts/cleanup-sessions.mjs",
    "db:migrate:remote": "pnpm --filter @incident/worker run db:migrate:remote",
    "dev:web": "pnpm --filter @incident/web run dev",
    "dev:worker": "pnpm --filter @incident/worker run dev",
    "worktrees:list": "git worktree list",
    "audit:coupling": "node scripts/audit-coupling.mjs",
    "audit:schema-sync": "node scripts/audit-schema-sync.mjs",
    "audit:route-body": "node scripts/audit-route-body.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware && pnpm run lint:pure",
    "lint:fix": "oxlint --type-aware --fix",
    "lint:pure": "eslint --max-warnings 0",
    "prepare": "lefthook install",
    "ci:test": "pnpm run build:scenarios && pnpm run check:sandbox-assets && pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test:coverage:check && pnpm run test:integration && pnpm run audit:schema-sync && pnpm run audit:route-body && pnpm run audit:coupling -- --strict && pnpm run perf:bench"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "effect": "^3.21.4",
    "eslint": "^10.7.0",
    "eslint-plugin-functional": "^10.0.0",
    "globals": "^17.6.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-config-presets": "^0.1.16",
    "oxlint-tsgolint": "^0.24.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.9.0"
}
